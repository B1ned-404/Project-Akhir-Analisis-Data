      "source": [
        "Q1 = product_orders[\"price\"].quantile(0.25)\n",
        "Q3 = product_orders[\"price\"].quantile(0.75)\n",
        "\n",
        "IQR = Q3 - Q1\n",
        "\n",
        "lower_bound = Q1 - 1.5 * IQR\n",
        "upper_bound = Q3 + 1.5 * IQR\n",
        "\n",
        "\n",
        "price_outliers = product_orders[\n",
        "    (product_orders[\"price\"] < lower_bound) |\n",
        "    (product_orders[\"price\"] > upper_bound)\n",
        "]\n",
        "\n",
        "print(\"Jumlah outlier:\", len(price_outliers))\n",
        "price_outliers.head()\n",
        "\n",
        "plt.figure(figsize=(8,5))\n",
        "plt.boxplot(product_orders[\"price\"])\n",
        "plt.title(\"Jumlah Penyebaran Harga Produk\")\n",
        "plt.xlabel(\"Product\")\n",
        "plt.ylabel(\"Price\")\n",
        "plt.xticks([])\n",
        "plt.show()\n",
        "\n",
        "plt.figure(figsize=(8,5))\n",
        "plt.hist(product_orders[\"price\"], bins=50)\n",
        "plt.title(\"Distribusi Harga Produk\")\n",
        "plt.xlabel(\"Price\")\n",
        "plt.ylabel(\"Frequency\")\n",
        "plt.show()\n",
        "\n",
        "plt.figure(figsize=(8,5))\n",
        "plt.boxplot(payment_method[\"payment_value\"])\n",
        "plt.title(\"Jumlah Penyebaran Pembayaran Customer\")\n",
        "plt.xlabel(\"Customer\")\n",
        "plt.ylabel(\"Payment\")\n",
        "plt.xticks([])\n",
        "plt.show()"
      ]
    },
