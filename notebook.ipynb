        "    customer_data\n",
        "    .groupby(\"customer_id\")\n",
        "    .agg(\n",
        "        total_orders=(\"order_id\",\"nunique\"),\n",
        "        total_payment=(\"payment_value\",\"sum\"),\n",
        "        avg_review=(\"review_score\",\"mean\"),\n",
        "        total_reviews=(\"review_score\",\"count\")\n",
        "    )\n",
        "    .reset_index()\n",
        ")\n",
        "\n",
        "customer_transactions.head(10)"
      ]
    },
